# Frontend environment variables (Vite reads from project root via envDir)
# Copy values to ../.env or set here if envDir points to frontend/

# When /api/tts fails, fall back to browser Web Speech API
VITE_TTS_FALLBACK_PROVIDER=browser

# Avatar — Supabase base (recommended for Vercel; no backend /api/avatar needed)
# Public base only, no trailing slash. Videos at fixed paths under base:
#   idle/idle-01.mp4 … idle/idle-03.mp4
#   speaking/speaking-01.mp4 … speaking-06.mp4
#   states/user-typing.mp4, states/counselor-connect.mp4
VITE_SUPABASE_AVATAR_BASE_URL=

# Avatar — minimal single-URL fallback (optional instead of Supabase base)
# VITE_AVATAR_IDLE_VIDEO_URL=https://.../junhyuk_idle.mp4
# VITE_AVATAR_SPEAKING_VIDEO_URL=https://.../junhyuk_speaking.mp4

# Local Windows dev (copy to frontend/.env.local or project root .env)
# Leave empty to use same-origin /api via Vite dev proxy → http://127.0.0.1:8000
VITE_API_BASE_URL=http://localhost:8000

# Vercel production (Project Settings → Environment Variables):
#   VITE_API_BASE_URL=https://retriever-craftily-mauve.ngrok-free.dev
# After changing env vars on Vercel, redeploy the frontend (env is baked in at build time).
