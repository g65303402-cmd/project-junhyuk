# api_server.py — master branch local defaults (copy to .env)
MOCK_MODE=true
MODEL_NAME=./output/exaone30-junhyuk-final
BASE_MODEL=LGAI-EXAONE/EXAONE-3.0-7.8B-Instruct
TTS_BASE_URL=http://127.0.0.1:5001
MAX_NEW_TOKENS=350
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Hugging Face (EXAONE base download — leave empty until login)
HF_TOKEN=

# Optional: GPU server memory limits (omit for local RTX 3060)
# MODEL_MAX_MEMORY_GPU=35GiB
# MODEL_MAX_MEMORY_CPU=10GiB

# Frontend (Vite envDir = project root — copy to .env)
# Default: leave VITE_API_BASE_URL unset → browser calls /api/* via Vite proxy (5173 → 8000)
# VITE_API_BASE_URL=
# Direct API call (cross-origin) only when needed:
# VITE_API_BASE_URL=http://localhost:8000
# mock stage: browser TTS (master api_server has no /api/tts)
VITE_TTS_PROVIDER=browser
VITE_TTS_FALLBACK_PROVIDER=browser
